{
    "openapi": "3.1.0",
    "info": {
        "title": "Seasonvar Mobile API",
        "version": "1.0.0",
        "description": "Стабильный JSON API каталога Seasonvar для мобильных клиентов."
    },
    "servers": [
        {
            "url": "/",
            "description": "Текущий хост Seasonvar"
        }
    ],
    "paths": {
        "/api": {
            "get": {
                "operationId": "getApiDiscovery",
                "summary": "Получить discovery-манифест API",
                "responses": {
                    "200": {
                        "description": "Версия и возможности API"
                    }
                }
            }
        },
        "/api/openapi.json": {
            "get": {
                "operationId": "getOpenApiDocument",
                "summary": "Получить OpenAPI-документ",
                "responses": {
                    "200": {
                        "description": "OpenAPI 3.1 document"
                    }
                }
            }
        },
        "/api/v1/config": {
            "get": {
                "operationId": "getApiConfig",
                "summary": "Получить безопасную конфигурацию клиента",
                "responses": {
                    "200": {
                        "description": "Presentation-safe настройки мобильного клиента"
                    }
                }
            }
        },
        "/api/v1/health": {
            "get": {
                "operationId": "getApiHealth",
                "summary": "Проверить доступность API",
                "responses": {
                    "200": {
                        "description": "API доступен"
                    },
                    "500": {
                        "$ref": "#/components/responses/ServerError"
                    }
                }
            }
        },
        "/api/v1/home": {
            "get": {
                "operationId": "getMobileHome",
                "summary": "Получить главную страницу мобильного каталога",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ограниченные публичные подборки каталога",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CatalogHomeResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/catalog/filters": {
            "get": {
                "operationId": "getCatalogFilterSchema",
                "summary": "Получить схему фильтров каталога",
                "responses": {
                    "200": {
                        "description": "Параметры, варианты и ограничения фильтров",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CatalogFilterSchemaResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/catalog/directories": {
            "get": {
                "operationId": "getCatalogDirectories",
                "summary": "Получить список справочников каталога",
                "responses": {
                    "200": {
                        "description": "Доступные справочники",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "data"
                                    ],
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/CatalogDirectory"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/catalog/directories/{directory}": {
            "get": {
                "operationId": "getCatalogDirectoryItems",
                "summary": "Получить элементы справочника каталога",
                "parameters": [
                    {
                        "name": "directory",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "genres",
                                "countries",
                                "actors",
                                "directors",
                                "age-ratings",
                                "translations",
                                "statuses",
                                "networks",
                                "studios",
                                "tags",
                                "years"
                            ]
                        }
                    },
                    {
                        "name": "q",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "maxLength": 80
                        }
                    },
                    {
                        "name": "letter",
                        "in": "query",
                        "description": "Одна кириллическая или латинская буква либо #",
                        "schema": {
                            "type": "string",
                            "maxLength": 1
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "name_asc",
                                "count_desc"
                            ],
                            "default": "name_asc"
                        }
                    },
                    {
                        "name": "decade",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "multipleOf": 10
                        }
                    },
                    {
                        "$ref": "#/components/parameters/Page"
                    },
                    {
                        "$ref": "#/components/parameters/PerPage"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Страница элементов справочника",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CatalogDirectoryItemsResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationError"
                    }
                }
            }
        },
        "/api/v1/titles/{titleSlug}": {
            "get": {
                "operationId": "getCatalogTitle",
                "summary": "Получить карточку тайтла",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/TitleSlug"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Публичные метаданные и безопасное состояние тайтла",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CatalogTitleResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            }
        },
        "/api/v1/titles/{titleSlug}/seasons": {
            "get": {
                "operationId": "getCatalogTitleSeasons",
                "summary": "Получить доступные сезоны тайтла",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/TitleSlug"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список доступных сезонов",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "data"
                                    ],
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Season"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            }
        },
        "/api/v1/titles/{titleSlug}/seasons/{season}/episodes": {
            "get": {
                "operationId": "getCatalogSeasonEpisodes",
                "summary": "Получить доступные серии сезона",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/TitleSlug"
                    },
                    {
                        "name": "season",
                        "in": "path",
                        "required": true,
                        "description": "Идентификатор сезона, принадлежащего выбранному тайтлу",
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список серий и безопасных media-профилей",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "data"
                                    ],
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Episode"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            }
        },
        "/api/v1/search/suggestions": {
            "get": {
                "operationId": "getSearchSuggestions",
                "summary": "Получить поисковые подсказки",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "minLength": 2,
                            "maxLength": 80
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "До пяти тайтлов, актёров и режиссёров каждого типа",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "data",
                                        "meta"
                                    ],
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "maxItems": 15,
                                            "items": {
                                                "$ref": "#/components/schemas/SearchSuggestion"
                                            }
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationError"
                    }
                }
            }
        },
        "/api/v1/titles/{titleSlug}/recommendations": {
            "get": {
                "operationId": "getCatalogTitleRecommendations",
                "summary": "Получить рекомендации тайтла",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/TitleSlug"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ранжированные видимые рекомендации без алгоритмических весов",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "data"
                                    ],
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/CatalogRecommendation"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            }
        },
        "/api/v1/titles/{titleSlug}/reviews": {
            "get": {
                "operationId": "getCatalogTitleReviews",
                "summary": "Получить импортированные отзывы тайтла",
                "security": [
                    {},
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/TitleSlug"
                    },
                    {
                        "$ref": "#/components/parameters/Page"
                    },
                    {
                        "$ref": "#/components/parameters/PerPage"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Пагинированные публичные тексты отзывов",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "required": [
                                        "data",
                                        "links",
                                        "meta"
                                    ],
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/CatalogReview"
                                            }
                                        },
                                        "links": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationError"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "Sanctum"
            }
        },
        "parameters": {
            "Page": {
                "name": "page",
                "in": "query",
                "schema": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 1
                }
            },
            "PerPage": {
                "name": "per_page",
                "in": "query",
                "schema": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 50,
                    "default": 20
                }
            },
            "TitleSlug": {
                "name": "titleSlug",
                "in": "path",
                "required": true,
                "schema": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "schemas": {
            "ApiError": {
                "type": "object",
                "required": [
                    "code",
                    "message",
                    "request_id"
                ],
                "properties": {
                    "code": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "request_id": {
                        "type": "string"
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "CatalogAlphabet": {
                "type": "object",
                "required": [
                    "cyrillic",
                    "latin",
                    "other"
                ],
                "properties": {
                    "cyrillic": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "latin": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "other": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "CatalogDirectory": {
                "type": "object",
                "required": [
                    "key",
                    "path",
                    "title",
                    "supports_alphabet",
                    "default_per_page",
                    "links"
                ],
                "properties": {
                    "key": {
                        "type": "string"
                    },
                    "path": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "item_label": {
                        "type": "string"
                    },
                    "filter_type": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "supports_alphabet": {
                        "type": "boolean"
                    },
                    "default_per_page": {
                        "type": "integer"
                    },
                    "links": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string",
                            "format": "uri"
                        }
                    }
                }
            },
            "CatalogDirectoryItem": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "slug",
                    "year",
                    "titles_count"
                ],
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "slug": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "year": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "titles_count": {
                        "type": "integer",
                        "minimum": 0
                    }
                }
            },
            "CatalogDirectoryItemsResponse": {
                "type": "object",
                "required": [
                    "data",
                    "links",
                    "meta"
                ],
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CatalogDirectoryItem"
                        }
                    },
                    "links": {
                        "type": "object"
                    },
                    "meta": {
                        "type": "object",
                        "required": [
                            "current_page",
                            "last_page",
                            "alphabet"
                        ],
                        "properties": {
                            "current_page": {
                                "type": "integer"
                            },
                            "last_page": {
                                "type": "integer"
                            },
                            "alphabet": {
                                "$ref": "#/components/schemas/CatalogAlphabet"
                            }
                        },
                        "additionalProperties": true
                    }
                }
            },
            "CatalogFilterSchemaResponse": {
                "type": "object",
                "required": [
                    "data"
                ],
                "properties": {
                    "data": {
                        "type": "object",
                        "required": [
                            "controls",
                            "sorts",
                            "alphabet"
                        ],
                        "properties": {
                            "controls": {
                                "type": "array",
                                "items": {
                                    "type": "object"
                                }
                            },
                            "sorts": {
                                "type": "array",
                                "items": {
                                    "type": "object"
                                }
                            },
                            "alphabet": {
                                "$ref": "#/components/schemas/CatalogAlphabet"
                            }
                        },
                        "additionalProperties": true
                    }
                }
            },
            "CatalogHomeResponse": {
                "type": "object",
                "required": [
                    "data"
                ],
                "properties": {
                    "data": {
                        "type": "object",
                        "required": [
                            "stats",
                            "latest_titles",
                            "featured_titles",
                            "titles_with_video",
                            "latest_releases",
                            "year_buckets",
                            "genres",
                            "countries"
                        ],
                        "additionalProperties": true
                    }
                }
            },
            "MediaProfile": {
                "type": "object",
                "required": [
                    "id",
                    "translation",
                    "variant",
                    "variant_key",
                    "quality",
                    "format",
                    "duration_seconds"
                ],
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "translation": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "variant": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "variant_key": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "quality": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "format": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "duration_seconds": {
                        "type": [
                            "integer",
                            "null"
                        ],
                        "minimum": 0
                    }
                }
            },
            "Season": {
                "type": "object",
                "required": [
                    "id",
                    "number",
                    "kind",
                    "title",
                    "counts",
                    "media_profiles",
                    "links"
                ],
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "number": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "kind": {
                        "type": "string"
                    },
                    "title": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "counts": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "integer"
                        }
                    },
                    "media_profiles": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MediaProfile"
                        }
                    },
                    "links": {
                        "type": "object"
                    }
                },
                "additionalProperties": true
            },
            "Episode": {
                "type": "object",
                "required": [
                    "id",
                    "season_id",
                    "number",
                    "kind",
                    "title",
                    "counts",
                    "media_profiles"
                ],
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "season_id": {
                        "type": "integer"
                    },
                    "number": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "kind": {
                        "type": "string"
                    },
                    "title": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "counts": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "integer"
                        }
                    },
                    "media_profiles": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MediaProfile"
                        }
                    }
                },
                "additionalProperties": true
            },
            "CatalogTitleResponse": {
                "type": "object",
                "required": [
                    "data"
                ],
                "properties": {
                    "data": {
                        "type": "object",
                        "required": [
                            "id",
                            "slug",
                            "title",
                            "aliases",
                            "ratings",
                            "rating_summary",
                            "taxonomies",
                            "counts",
                            "primary_action",
                            "links"
                        ],
                        "additionalProperties": true
                    }
                }
            },
            "SearchSuggestion": {
                "type": "object",
                "required": [
                    "type",
                    "label",
                    "slug",
                    "title_slug",
                    "count"
                ],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "title",
                            "actor",
                            "director"
                        ]
                    },
                    "label": {
                        "type": "string"
                    },
                    "slug": {
                        "type": "string"
                    },
                    "title_slug": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "count": {
                        "type": "integer",
                        "minimum": 0
                    }
                }
            },
            "CatalogRecommendation": {
                "type": "object",
                "required": [
                    "rank",
                    "reasons",
                    "title"
                ],
                "properties": {
                    "rank": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "reasons": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "title": {
                        "type": "object",
                        "additionalProperties": true
                    }
                }
            },
            "CatalogReview": {
                "type": "object",
                "required": [
                    "id",
                    "author",
                    "body",
                    "published_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "author": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "body": {
                        "type": "string"
                    },
                    "published_at": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    }
                }
            }
        },
        "responses": {
            "NotFound": {
                "description": "Ресурс не найден",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/ApiError"
                        }
                    }
                }
            },
            "ValidationError": {
                "description": "Ошибка валидации параметров",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/ApiError"
