APP_NAME="Каталог сериалов"
APP_ENV=local
APP_KEY=
APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_MODEL=App\Models\User
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=debug
LOG_DAILY_DAYS=14
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_USERNAME="${APP_NAME}"
# LOG_SLACK_EMOJI=:boom:
# LOG_PAPERTRAIL_HANDLER=Monolog\Handler\SocketHandler
# PAPERTRAIL_URL=
# PAPERTRAIL_PORT=
# LOG_STDERR_FORMATTER=
# LOG_SYSLOG_FACILITY=

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite
DB_FOREIGN_KEYS=true
DB_BUSY_TIMEOUT=10000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal
DB_TRANSACTION_MODE=IMMEDIATE
# DB_URL=
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_SOCKET=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_SSLMODE=prefer
# DB_ENCRYPT=yes
# DB_TRUST_SERVER_CERTIFICATE=false
# MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_CONNECTION=null
SESSION_TABLE=sessions
SESSION_STORE=null
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
LOCAL_FILESYSTEM_SERVE=false
UPLOADS_DISK=uploads
UPLOADS_MAX_IMAGE_KILOBYTES=2048
QUEUE_CONNECTION=database
DB_QUEUE_CONNECTION=null
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=1200
QUEUE_FAILED_DRIVER=database-uuids
# BEANSTALKD_QUEUE_HOST=localhost
# BEANSTALKD_QUEUE=default
# BEANSTALKD_QUEUE_RETRY_AFTER=1200
# SQS_PREFIX=https://sqs.us-east-1.amazonaws.com/your-account-id
# SQS_QUEUE=default
# SQS_SUFFIX=

CACHE_STORE=database
CACHE_LIMITER_STORE=file
DB_CACHE_CONNECTION=null
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=null
DB_CACHE_LOCK_TABLE=null
CACHE_STORAGE_DISK=null
CACHE_STORAGE_PATH=framework/cache/data
# CACHE_PREFIX=
# DYNAMODB_CACHE_TABLE=cache
# DYNAMODB_ENDPOINT=

MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=null
MEMCACHED_PASSWORD=null
MEMCACHED_PERSISTENT_ID=null

REDIS_CLIENT=phpredis
REDIS_URL=null
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CLUSTER=redis
# REDIS_PREFIX=
REDIS_PERSISTENT=false
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=1200

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_URL=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_EHLO_DOMAIN=null
MAIL_LOG_CHANNEL=null
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
NOTIFICATIONS_MAIL_QUEUE=default
SEASONVAR_IMPORT_FAILURE_MAIL_TO=
SEASONVAR_IMPORT_FAILURE_MAIL_TO_NAME=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

POSTMARK_API_KEY=
# POSTMARK_MESSAGE_STREAM_ID=
RESEND_API_KEY=
