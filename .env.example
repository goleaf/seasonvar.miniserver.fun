SEASONVAR_CRAWL_DELAY=3
SEASONVAR_IMPORT_CHUNK_SIZE=100
SEASONVAR_IMPORT_SLEEP_SECONDS=60
SEASONVAR_IMPORT_REFRESH_AFTER_HOURS=24
SEASONVAR_IMPORT_MISSING_DATA_RETRY_HOURS=24
SEASONVAR_IMPORT_LOCK_SECONDS=604800
SEASONVAR_IMPORT_STALE_AFTER_MINUTES=15
SEASONVAR_IMPORT_TRANSACTION_ATTEMPTS=5
SEASONVAR_IMPORT_TRANSACTION_RETRY_DELAY_MS=250
SEASONVAR_IMPORT_STORAGE_MAINTENANCE_ENABLED=true
SEASONVAR_IMPORT_EVENT_RETENTION_DAYS=7
SEASONVAR_IMPORT_SNAPSHOT_RETENTION_DAYS=14
SEASONVAR_IMPORT_MAINTENANCE_CHUNK_SIZE=500
SEASONVAR_QUEUE_CONNECTION=redis
SEASONVAR_QUEUE_NAME=seasonvar-import
SEASONVAR_QUEUE_LOCK_STORE=redis
SEASONVAR_QUEUE_CLAIM_SECONDS=86400
SEASONVAR_QUEUE_WORKER_TIMEOUT=900
SEASONVAR_QUEUE_RETRY_WINDOW_SECONDS=21600
SEASONVAR_QUEUE_FINALIZER_DELAY_SECONDS=60
SEASONVAR_QUEUE_BUSY_THRESHOLD=5000
SEASONVAR_QUEUE_BUSY_LOG_SECONDS=3600
SEASONVAR_MEDIA_CHECK_ENABLED=true
