#!/usr/bin/env bash
set -euo pipefail

if [[ "${SEASONVAR_SKIP_GIT_GUARD:-}" == "1" ]]; then
    exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

source "$repo_root/.githooks/lib/git-guard.sh"

seasonvar_git_guard_require_main
seasonvar_git_guard_require_no_conflicts
seasonvar_git_guard_require_safe_paths tracked
seasonvar_git_guard_require_clean_tree

bash "$repo_root/scripts/ci-check.sh" pre-push
